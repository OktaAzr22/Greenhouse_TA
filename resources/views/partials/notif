<script>
  // Area Chart
  const ctx = document.getElementById('areaChart').getContext('2d');
  new Chart(ctx, {
    type: 'line',
    data: {
      labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
      datasets: [{
        label: 'Revenue ($)',
        data: [12500, 15800, 14200, 18900, 22400, 27800],
        borderColor: 'rgb(16, 185, 129)',
        backgroundColor: 'rgba(16, 185, 129, 0.1)',
        borderWidth: 3,
        fill: true,
        tension: 0.4,
        pointBackgroundColor: 'rgb(16, 185, 129)',
        pointBorderColor: '#fff',
        pointBorderWidth: 2,
        pointRadius: 4,
        pointHoverRadius: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: true,
      plugins: {
        legend: { display: true, position: 'top', labels: { usePointStyle: true, boxWidth: 6 } },
        tooltip: { callbacks: { label: function(context) { return `Revenue: $${context.raw.toLocaleString()}`; } } }
      },
      scales: {
        y: { beginAtZero: true, ticks: { callback: function(value) { return '$' + value.toLocaleString(); } }, grid: { color: 'rgba(0,0,0,0.05)' } },
        x: { grid: { display: false } }
      }
    }
  });

  // NOTIFICATION BUTTON dengan DROPDOWN
  let scrollTimeout;
  const notificationBtn = document.getElementById('notificationBtn');
  const notificationDropdown = document.getElementById('notificationDropdown');
  const notificationWrapper = document.getElementById('notificationWrapper');
  const mainContent = document.getElementById('mainContent');
  
  // Toggle dropdown saat icon diklik
  notificationBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    const isHidden = notificationDropdown.classList.contains('hidden');
    
    // Tutup semua dropdown lain jika ada
    closeAllDropdowns();
    
    if (isHidden) {
      notificationDropdown.classList.remove('hidden');
      notificationDropdown.classList.add('dropdown-show');
      // Hapus class animasi setelah selesai
      setTimeout(() => {
        notificationDropdown.classList.remove('dropdown-show');
      }, 200);
    } else {
      notificationDropdown.classList.add('hidden');
    }
  });
  
  // Tutup dropdown saat klik di luar
  document.addEventListener('click', function(event) {
    if (!notificationWrapper.contains(event.target)) {
      notificationDropdown.classList.add('hidden');
    }
  });
  
  function closeAllDropdowns() {
    notificationDropdown.classList.add('hidden');
  }
  
  // Fungsi untuk hide/show notifikasi saat scroll
  function hideNotification() {
    if (notificationBtn) {
      notificationBtn.classList.add('translate-y-20', 'opacity-0');
      notificationBtn.classList.remove('translate-y-0', 'opacity-100');
      // Tutup dropdown juga saat scroll
      notificationDropdown.classList.add('hidden');
    }
  }
  
  function showNotification() {
    if (notificationBtn) {
      notificationBtn.classList.remove('translate-y-20', 'opacity-0');
      notificationBtn.classList.add('translate-y-0', 'opacity-100');
    }
  }
  
  // Event listener untuk scroll
  if (mainContent) {
    mainContent.addEventListener('scroll', function() {
      hideNotification();
      
      if (scrollTimeout) clearTimeout(scrollTimeout);
      
      scrollTimeout = setTimeout(function() {
        showNotification();
      }, 300);
    });
  }
  
  // Klik item notifikasi
  document.querySelectorAll('#notificationDropdown .cursor-pointer').forEach(item => {
    item.addEventListener('click', function() {
      console.log('Notifikasi diklik:', this);
      notificationDropdown.classList.add('hidden');
      // Di sini bisa tambahkan logic untuk redirect atau aksi lain
    });
  });
  
  // Klik "Lihat semua notifikasi"
  document.querySelector('#notificationDropdown button').addEventListener('click', function() {
    alert('Membuka halaman semua notifikasi...');
    notificationDropdown.classList.add('hidden');
  });
</script>